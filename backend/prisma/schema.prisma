// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// AUTHENTICATION & USER MANAGEMENT
// ============================================

enum Role {
  DEVELOPER
  SUPER_ADMIN
  ADMIN
  KASIR
  CASHIER_SUPERVISOR
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

model User {
  id                  String    @id @default(cuid())
  email               String?   @unique
  username            String?   @unique
  passwordHash        String
  fullName            String?
  phone               String?
  address             String?
  avatarUrl           String?
  role                Role      @default(KASIR)
  status              UserStatus @default(ACTIVE)
  shop                Shop?     @relation("ShopUsers", fields: [shopId], references: [id])
  shopId              String?
  tenant              Tenant?   @relation(fields: [tenantId], references: [id])
  tenantId            String?
  
  mustChangePassword  Boolean   @default(false)
  mustChangePin       Boolean   @default(false)
  /** 2FA OTP via email. Default true untuk SUPER_ADMIN, false untuk role lain. */
  otpEnabled          Boolean   @default(false)
  pin                 String?   // bcrypt hash of 4-6 digit PIN for kasir login
  pinChangedAt        DateTime? @map("pin_changed_at")
  pinAttempts         Int       @default(0) @map("pin_attempts")
  pinLockedUntil      DateTime? @map("pin_locked_until")
  
  // Email verification for kasir
  emailVerifiedAt         DateTime? @map("email_verified_at")
  emailVerificationCode   String?   @map("email_verification_code")
  emailCodeExpiresAt      DateTime? @map("email_code_expires_at")
  lastLogin           DateTime?
  lastPasswordReset   DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  
  sessions            Session[]
  activityLogs        ActivityLog[]
  transactions        Transaction[]
  shifts              Shift[]
  cashFlows           CashFlow[]
  ownedShops          Shop[]    @relation("ShopOwner")
  brilinkTransactions BrilinkTransaction[] @relation("BrilinkCashier")
  brilinkMutations    BrilinkMutation[]    @relation("BrilinkMutationCreator")
  stockHistories      StockHistory[]       @relation("StockHistoryCreator")
  opnameSessions      OpnameSession[]      @relation("OpnameConductor")
  opnameAssignments   OpnameSession[]      @relation("OpnameAssignee")
  purchaseOrders      PurchaseOrder[]      @relation("POCreator")
  transferRequests    StockTransfer[]      @relation("TransferRequester")
  transferApprovals   StockTransfer[]      @relation("TransferApprover")

  @@index([shopId])
  @@index([email])
  @@map("users")
}

model Session {
  id                  String    @id @default(cuid())
  user                User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId              String
  token               String    @unique
  refreshToken        String    @unique
  expiresAt           DateTime
  refreshExpiresAt    DateTime
  ipAddress           String?
  userAgent           String?
  createdAt           DateTime  @default(now())
  
  @@index([userId])
  @@index([token])
  @@map("sessions")
}

model ActivityLog {
  id                  String    @id @default(cuid())
  user                User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId              String
  action              String    // LOGIN, TRANSACTION, VOID, etc
  resource            String?   // TRANSACTION, PRODUCT, STOCK, etc
  resourceId          String?
  details             String?   // JSON details
  ipAddress           String?
  createdAt           DateTime  @default(now())
  
  @@index([userId])
  @@index([createdAt])
  @@map("activity_logs")
}

// ============================================
// SHOP MANAGEMENT
// ============================================

model Shop {
  id                  String    @id @default(cuid())
  name                String
  address             String
  phone               String
  owner               User?     @relation("ShopOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  ownerId             String?
  tenant              Tenant?   @relation(fields: [tenantId], references: [id])
  tenantId            String?
  parentShop          Shop?     @relation("ShopToParent", fields: [parentShopId], references: [id], onDelete: SetNull)
  parentShopId        String?
  childShops          Shop[]    @relation("ShopToParent")
  
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  
  users               User[]    @relation("ShopUsers")
  products            Product[]
  stocks              Stock[]
  transactions        Transaction[]
  debts               Debt[]
  payments            Payment[]
  cashBoxes           CashBox[]
  cashMutations       CashMutation[]
  shifts              Shift[]
  settings            ShopSetting?
  productCategories   ProductCategory[]
  cashFlowCategories  CashFlowCategory[]
  cashFlows           CashFlow[]
  brilinkTransactions BrilinkTransaction[]
  brilinkFees         BrilinkFee[]
  brilinkAccounts     BrilinkAccount[]
  brilinkCashBox      BrilinkCashBox?
  brilinkReconciliations BrilinkReconciliation[]
  brilinkProducts     BrilinkProduct[]
  opnameSessions      OpnameSession[]
  suppliers           Supplier[]
  purchaseOrders      PurchaseOrder[]
  transfersOut        StockTransfer[]      @relation("TransferFrom")
  transfersIn         StockTransfer[]      @relation("TransferTo")
  rackZones           RackZone[]
  racks               Rack[]
  customers           Customer[]
  tripayConfig        TripayConfig?
  ppobTransactions    PpobTransaction[]

  @@map("shops")
}

model ShopSetting {
  id                  String    @id @default(cuid())
  shop                Shop      @relation(fields: [shopId], references: [id], onDelete: Cascade)
  shopId              String    @unique
  language            String    @default("id")
  timezone            String    @default("Asia/Jakarta") // WIB=Asia/Jakarta, WITA=Asia/Makassar, WIT=Asia/Jayapura
  receiptConfig       String?
  alertConfig         Json?
  brilinkCategoryConfig Json?

  // Module toggles
  brilinkEnabled              Boolean @default(true)

  // Shift settings
  shiftMode                   String  @default("FLOWING") // FLOWING | RESET
  shiftForceCloseOnSwitch     Boolean @default(true)
  shiftCorrectionRequired     Boolean @default(true)
  shiftPhysicalCountRequired  Boolean @default(true)
  shiftGuardEnabled           Boolean @default(true)

  // Kas
  cashOutApprovalEnabled      Boolean @default(true)

  // Payment methods
  paymentCashEnabled          Boolean @default(true)
  paymentQrisEnabled          Boolean @default(true)
  paymentHutangEnabled        Boolean @default(true)

  // POS features
  saveBillEnabled             Boolean @default(true)
  discountPerItemEnabled      Boolean @default(true)
  discountTotalEnabled        Boolean @default(true)
  notePerItemEnabled          Boolean @default(true)

  // Notification settings
  notifSoundEnabled           Boolean @default(true)
  notifSoundTone              String  @default("chime") // chime | beep | bell | silent

  /**
   * KPI targets for BRILink dashboard & transaction page.
   * JSON shape: {
   *   dailyTransactionTarget: number,   // target jumlah transaksi per hari (default 50)
   *   dailyVolumeTarget: number,        // target volume transaksi per hari in Rp (default 50_000_000)
   *   dailyFeeTarget: number,           // target fee/profit per hari in Rp (default 500_000)
   * }
   */
  brilinkKpiConfig    Json?

  updatedAt           DateTime  @updatedAt
  
  @@map("shop_settings")
}

// ============================================
// CASH BOX CATEGORIES (multi-kas)
// ============================================
//
// Toko bisa punya beberapa "kas" terpisah yang regulasi/audit-nya beda:
// - RETAIL: kas penjualan biasa (default)
// - SUBSIDI_PUPUK: kas subsidi pemerintah, terpisah karena ada laporan ke
//   Pupuk Indonesia / Kementan dan margin diatur HET pemerintah
// - LPG_SUBSIDI / BERAS_BULOG / dll bisa ditambah via admin panel
//
// CashBoxCategory di-manage SUPER_ADMIN saja (global, semua cabang pakai
// kategori yang sama biar reporting cross-cabang konsisten).
//
// Per cabang akan punya saldo terpisah lewat ShiftCashBox (akumulasi dari
// shift-shift yang sudah finalized).

model CashBoxCategory {
  id            String    @id @default(cuid())
  code          String    @unique // "RETAIL", "SUBSIDI_PUPUK", dst (UPPERCASE)
  name          String              // "Kas Retail", "Kas Subsidi Pupuk"
  description   String?
  /** Tailwind color class (mis "blue", "amber") atau hex untuk badge UI */
  color         String?
  /** Lucide icon name, mis "shopping-cart", "wheat" */
  icon          String?
  /** Default category yang dipakai kalau produk belum di-assign kategori. */
  isDefault     Boolean   @default(false)
  /** Soft-disable. False = tidak tampil di UI buka shift / POS. */
  isActive      Boolean   @default(true)
  sortOrder     Int       @default(0)

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  shiftCashBoxes ShiftCashBox[]

  @@index([isActive, sortOrder])
  @@map("cash_box_categories")
}

// ============================================
// PRODUCTS & INVENTORY
// ============================================

model Product {
  id                  String    @id @default(cuid())
  shop                Shop      @relation(fields: [shopId], references: [id], onDelete: Cascade)
  shopId              String
  name                String
  sku                 String                // kode internal toko (auto-generated)
  barcode             String?               // EAN/UPC dari pabrik (nullable, untuk scan POS)
  price               Int       // in rupiah
  cost                Int       // in rupiah
  supplierId          String?   // future: Supplier model
  category            ProductCategory? @relation(fields: [categoryId], references: [id])
  categoryId          String?
  imageUrl            String?   // Cloudinary URL
  unit                String?   // satuan: pcs, kg, liter, dll
  description         String?
  
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  deletedAt           DateTime?
  
  stocks              Stock[]
  transactionItems    TransactionItem[]
  debts               Debt[]
  opnameItems         OpnameItem[]
  purchaseOrderItems  PurchaseOrderItem[]
  stockTransferItems  StockTransferItem[]

  @@unique([shopId, sku])
  @@index([shopId])
  @@index([categoryId])
  @@index([shopId, barcode])
  @@map("products")
}

model ProductCategory {
  id          String    @id @default(cuid())
  shop        Shop      @relation(fields: [shopId], references: [id], onDelete: Cascade)
  shopId      String
  name        String    // "Makanan", "Minuman", "Sembako", dll
  icon        String?   // emoji or Lucide icon name
  color       String?   // Tailwind color
  sortOrder   Int       @default(0)
  isActive    Boolean   @default(true)
  
  products    Product[]
  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([shopId, name])
  @@index([shopId, isActive])
  @@map("product_categories")
}

model Stock {
  id                  String    @id @default(cuid())
  shop                Shop      @relation(fields: [shopId], references: [id], onDelete: Cascade)
  shopId              String
  product             Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId           String
  quantity            Int       @default(0)
  warehouse           String?   @default("main")
  rack                Rack?     @relation(fields: [rackId], references: [id], onDelete: SetNull)
  rackId              String?
  
  updatedAt           DateTime  @updatedAt
  
  stockHistories      StockHistory[]

  @@unique([shopId, productId, warehouse])
  @@index([shopId])
  @@index([productId])
  @@index([rackId])
  @@map("stocks")
}

enum StockHistoryType {
  IN
  OUT
  OPNAME
  TRANSFER_OUT
  TRANSFER_IN
  ADJUSTMENT
}

enum StockHistorySource {
  INITIAL          // saldo awal saat produk dibuat
  BULK_UPLOAD      // import Excel
  SEED             // seed data
  STOCK_IN         // restock manual
  SALE             // penjualan via POS
  SALE_VOID        // void penjualan (stok dikembalikan)
  OPNAME_INLINE    // opname cepat dari /stock
  OPNAME_SESSION   // opname dari sesi /opname
  TRANSFER_OUT     // transfer keluar ke cabang lain
  TRANSFER_IN      // transfer masuk dari cabang lain
  PURCHASE_ORDER   // PO dari supplier
  ADJUSTMENT       // penyesuaian manual lainnya
}

model StockHistory {
  id                  String    @id @default(cuid())
  stock               Stock     @relation(fields: [stockId], references: [id], onDelete: Cascade)
  stockId             String
  type                StockHistoryType
  source              StockHistorySource?  // alasan/sumber pergerakan stok
  paymentMethod       PaymentMethod?       // hanya untuk SALE (CASH/QRIS/TRANSFER/HUTANG)
  quantityBefore      Int
  quantityAfter       Int
  quantityChange      Int
  reference           String?   // transaction_id, opname_id, transfer_id, po_id
  notes               String?
  createdBy           User?     @relation("StockHistoryCreator", fields: [createdById], references: [id])
  createdById         String?   // user yang melakukan aksi (kasir/admin)
  
  createdAt           DateTime  @default(now())
  
  @@index([stockId])
  @@index([createdAt])
  @@index([source])
  @@map("stock_histories")
}

// ============================================
// TRANSACTIONS & SALES
// ============================================

enum TransactionStatus {
  PENDING
  COMPLETED
  VOIDED
  PROCESSING
}

enum PaymentMethod {
  CASH
  QRIS
  TRANSFER
  HUTANG
}

model Transaction {
  id                  String    @id @default(cuid())
  shop                Shop      @relation(fields: [shopId], references: [id], onDelete: Cascade)
  shopId              String
  user                User      @relation(fields: [userId], references: [id])
  userId              String
  transactionNumber   String    @unique
  
  totalPrice          Int       // in rupiah
  totalCost           Int       // in rupiah
  totalDiscount       Int       @default(0)
  status              TransactionStatus @default(PENDING)
  
  // Offline-ready fields
  // idempotencyKey: client-generated UUID untuk dedup retry saat sinyal jelek.
  //   Sama key = transaksi yang sama, server kembalikan record existing tanpa create dobel.
  // clientCreatedAt: waktu transaksi sebenarnya di sisi kasir (saat scan + bayar),
  //   bisa berbeda dari createdAt (yang ditulis saat sync ke server).
  idempotencyKey      String?   @unique
  clientCreatedAt     DateTime?
  
  // Optional customer link (auto-create jika nama baru)
  customer            Customer? @relation(fields: [customerId], references: [id])
  customerId          String?
  customerName        String?   // denormalized: nama pembeli saat transaksi
  customerPhone       String?   // denormalized: HP pembeli saat transaksi

  items               TransactionItem[]
  payments            Payment[]
  debt                Debt?
  
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  voidedAt            DateTime?
  voidedBy            String?   // admin username/id
  voidReason          String?
  
  @@index([shopId])
  @@index([userId])
  @@index([customerId])
  @@index([createdAt])
  @@map("transactions")
}

model TransactionItem {
  id                  String    @id @default(cuid())
  transaction         Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  transactionId       String
  product             Product   @relation(fields: [productId], references: [id])
  productId           String
  
  quantity            Int
  unitPrice           Int       // in rupiah (saat transaksi)
  discount            Int       @default(0)
  subtotal            Int       // quantity * unitPrice - discount
  
  @@index([transactionId])
  @@index([productId])
  @@map("transaction_items")
}

// ============================================
// PAYMENTS & CASH MANAGEMENT
// ============================================

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  CANCELLED
}

model Payment {
  id                  String    @id @default(cuid())
  shop                Shop      @relation(fields: [shopId], references: [id], onDelete: Cascade)
  shopId              String
  transaction         Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  transactionId       String
  
  method              PaymentMethod
  amount              Int       // in rupiah
  status              PaymentStatus @default(PENDING)
  reference           String?   // QRIS ref, transfer ref, etc
  
  createdAt           DateTime  @default(now())
  
  @@index([shopId])
  @@index([transactionId])
  @@map("payments")
}

model CashBox {
  id                  String    @id @default(cuid())
  shop                Shop      @relation(fields: [shopId], references: [id], onDelete: Cascade)
  shopId              String
  categoryId          String?   // link ke CashBoxCategory — null = kas utama legacy
  label               String    @default("Kas Utama")
  
  balance             Int       @default(0) // in rupiah
  lastAudit           DateTime?
  lastAuditBalance    Int?
  
  updatedAt           DateTime  @updatedAt
  
  @@unique([shopId, categoryId])
  @@index([shopId])
  @@map("cash_boxes")
}

model CashMutation {
  id              String    @id @default(cuid())
  shop            Shop      @relation(fields: [shopId], references: [id], onDelete: Cascade)
  shopId          String
  categoryId      String?   // link ke CashBoxCategory (kalau multi-kas)
  type            String    // CASH_IN | CASH_OUT
  amount          Int
  balanceBefore   Int
  balanceAfter    Int
  category        String?   // label kategori (MODAL_OPERASIONAL, dll)
  notes           String?
  createdAt       DateTime  @default(now())

  @@index([shopId])
  @@index([createdAt])
  @@index([categoryId])
  @@map("cash_mutations")
}

// ============================================
// DEBTS MANAGEMENT
// ============================================

enum DebtStatus {
  PENDING
  PARTIALLY_PAID
  PAID
  OVERDUE
  CANCELLED
}

model Debt {
  id                  String    @id @default(cuid())
  shop                Shop      @relation(fields: [shopId], references: [id], onDelete: Cascade)
  shopId              String

  // === Link ke transaksi (kalau hutang dari POS) ===
  transaction         Transaction? @relation(fields: [transactionId], references: [id])
  transactionId       String?   @unique

  // === Legacy single-product (backward compat, nullable sekarang) ===
  product             Product?  @relation(fields: [productId], references: [id])
  productId           String?

  // === Manual items (kalau hutang manual tanpa transaksi POS) ===
  // JSON array: [{ name: "Beras 5kg", qty: 2, price: 65000 }]
  manualItems         Json?
  
  customerName        String
  customerPhone       String?
  quantity            Int       @default(1)
  unitPrice           Int       @default(0)
  totalAmount         Int
  paidAmount          Int       @default(0)
  status              DebtStatus @default(PENDING)
  
  dueDate             DateTime?
  notes               String?
  
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  
  debtPayments        DebtPayment[]
  
  @@index([shopId])
  @@index([status])
  @@index([transactionId])
  @@map("debts")
}

model DebtPayment {
  id                  String    @id @default(cuid())
  debt                Debt      @relation(fields: [debtId], references: [id], onDelete: Cascade)
  debtId              String
  
  amount              Int       // in rupiah
  method              PaymentMethod
  reference           String?
  notes               String?
  
  createdAt           DateTime  @default(now())
  
  @@index([debtId])
  @@map("debt_payments")
}

// ============================================
// SHIFT MANAGEMENT & CLEREK
// ============================================

enum ShiftStatus {
  OPEN
  CLOSED
  FINALIZED
}

model Shift {
  id                  String    @id @default(cuid())
  shop                Shop      @relation(fields: [shopId], references: [id], onDelete: Cascade)
  shopId              String
  user                User      @relation(fields: [userId], references: [id])
  userId              String
  
  startTime           DateTime
  endTime             DateTime?
  
  status              ShiftStatus @default(OPEN)
  notes               String?
  finalizedAt         DateTime?
  finalizedBy         String?   // admin username
  
  /**
   * Per-category breakdown of cash & QRIS for this shift.
   * Setiap kategori (RETAIL, SUBSIDI_PUPUK, dst) punya 1 row di sini dengan
   * starting cash, expected vs actual, dan variance terpisah.
   *
   * Saat openShift: dibuat row per active category dengan startingCash dari
   *   input kasir.
   * Saat closeShift: expectedCash/QRIS dihitung dari transaksi shift, kasir
   *   input actualCash/QRIS, sistem hitung variance.
   */
  cashBoxes           ShiftCashBox[]
  cashFlows           CashFlow[]

  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  
  @@index([shopId])
  @@index([userId])
  @@index([status])
  @@map("shifts")
}

/**
 * Per-category snapshot dari shift. Satu Shift bisa punya beberapa
 * ShiftCashBox (mis: kas RETAIL + kas SUBSIDI_PUPUK).
 *
 * Diisi step-by-step:
 * 1. Open shift: startingCash di-input kasir, expected/actual masih 0/null.
 * 2. Selama shift: setiap transaksi update expectedCash/QRIS via service.
 *    (Untuk sekarang masih dihitung on-demand saat closeShift dari sum
 *     payments. Optimization caching bisa nanti.)
 * 3. Close shift: kasir input actualCash & actualQRIS, sistem hitung
 *    varianceCash & varianceQRIS.
 */
model ShiftCashBox {
  id                  String          @id @default(cuid())
  shift               Shift           @relation(fields: [shiftId], references: [id], onDelete: Cascade)
  shiftId             String
  category            CashBoxCategory @relation(fields: [categoryId], references: [id])
  categoryId          String

  startingCash        Int      @default(0) // input saat buka shift (rupiah)
  expectedCash        Int      @default(0) // computed dari payments CASH
  actualCash          Int?               // input saat tutup shift
  varianceCash        Int?               // actualCash - (startingCash + expectedCash)

  expectedQRIS        Int      @default(0) // computed dari payments QRIS
  actualQRIS          Int?
  varianceQRIS        Int?

  /**
   * Breakdown denominasi uang fisik saat tutup shift.
   * Format JSON object: { "100000": 5, "50000": 3, ..., "100": 0, "lainnya": 5000 }
   *  - key = nominal lembar/koin (rupiah string), kecuali "lainnya"
   *  - value = jumlah lembar (count) untuk semua kunci kecuali "lainnya"
   *  - "lainnya" = nominal raw (rupiah) untuk koin/recehan/lain yg tdk masuk slot.
   *
   * Optional: kalau kasir tidak input denominasi, field null. actualCash
   * tetap dipakai sebagai source of truth.
   *
   * Server validate: sum(key * value for key != "lainnya") + lainnya == actualCash.
   */
  cashDenominations   Json?

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@unique([shiftId, categoryId])
  @@index([shiftId])
  @@index([categoryId])
  @@map("shift_cash_boxes")
}

// ============================================
// CASH FLOW (Cash In / Cash Out)
// ============================================

model CashFlowCategory {
  id          String    @id @default(cuid())
  shop        Shop      @relation(fields: [shopId], references: [id], onDelete: Cascade)
  shopId      String
  name        String
  type        String    // CASH_IN | CASH_OUT
  icon        String?
  isActive    Boolean   @default(true)
  sortOrder   Int       @default(0)

  cashFlows   CashFlow[]

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([shopId, name, type])
  @@index([shopId, type, isActive])
  @@map("cash_flow_categories")
}

model CashFlow {
  id          String    @id @default(cuid())
  shop        Shop      @relation(fields: [shopId], references: [id], onDelete: Cascade)
  shopId      String
  user        User      @relation(fields: [userId], references: [id])
  userId      String
  shift       Shift?    @relation(fields: [shiftId], references: [id])
  shiftId     String?
  category    CashFlowCategory @relation(fields: [categoryId], references: [id])
  categoryId  String

  type        String    // CASH_IN | CASH_OUT
  amount      Int
  notes       String?

  // Approval
  status      String    @default("PENDING") // PENDING | VERIFIED | REJECTED
  verifiedBy  String?
  verifiedAt  DateTime?
  rejectReason String?

  createdAt   DateTime  @default(now())

  @@index([shopId, createdAt])
  @@index([shiftId])
  @@index([status])
  @@map("cash_flows")
}

// ============================================
// STOCK OPNAME SESSION MANAGEMENT
// ============================================

enum OpnameStatus {
  DRAFT
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

model OpnameSession {
  id              String        @id @default(cuid())
  shop            Shop          @relation(fields: [shopId], references: [id], onDelete: Cascade)
  shopId          String
  conductor       User          @relation("OpnameConductor", fields: [conductorId], references: [id])
  conductorId     String
  /** Petugas (kasir) yang ditugaskan menghitung fisik. null = belum di-assign */
  assignee        User?         @relation("OpnameAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  assigneeId      String?

  sessionNumber   String        @unique
  /**
   * Passcode 6 karakter (uppercase alphanumeric) untuk join sesi opname via webapp.
   * Generated saat admin buat sesi. Petugas input kode ini di webapp untuk mulai hitung.
   * Expired otomatis ketika sesi COMPLETED atau CANCELLED.
   */
  passcode        String        @unique
  status          OpnameStatus  @default(DRAFT)
  notes           String?
  startedAt       DateTime?
  completedAt     DateTime?

  /** Summary stats (computed on complete) */
  totalProducts   Int           @default(0)
  totalMatched    Int           @default(0)
  totalSurplus    Int           @default(0)
  totalDeficit    Int           @default(0)

  items           OpnameItem[]
  participants    OpnameParticipant[]

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([shopId])
  @@index([conductorId])
  @@index([assigneeId])
  @@index([status])
  @@index([createdAt])
  @@map("opname_sessions")
}

model OpnameItem {
  id              String        @id @default(cuid())
  session         OpnameSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  sessionId       String
  product         Product       @relation(fields: [productId], references: [id])
  productId       String

  systemQty       Int           // stok di sistem saat opname dimulai
  actualQty       Int?          // stok fisik yang dihitung
  variance        Int?          // actualQty - systemQty
  reason          String?       // HILANG | RUSAK | EXPIRED | SALAH_HITUNG | LAINNYA
  notes           String?
  /** Siapa yang menghitung item ini (reference ke OpnameParticipant) */
  countedById     String?

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@unique([sessionId, productId])
  @@index([sessionId])
  @@index([productId])
  @@map("opname_items")
}

/**
 * Peserta yang join sesi opname via passcode.
 * Satu sesi bisa punya banyak peserta (multi-device counting).
 * Nama diinput saat join (free text atau pilih dari list user).
 */
model OpnameParticipant {
  id              String        @id @default(cuid())
  session         OpnameSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  sessionId       String
  /** Nama petugas (free text, diisi saat join via passcode) */
  name            String
  /** Optional: link ke user jika petugas punya akun */
  userId          String?
  /** Device/browser identifier untuk tracking multi-device */
  deviceId        String?

  joinedAt        DateTime      @default(now())

  @@index([sessionId])
  @@map("opname_participants")
}

// ============================================
// BRILINK TRANSACTIONS & FEE MANAGEMENT
// ============================================

enum BrilinkCategory {
  TRANSFER_BRI
  TRANSFER_OTHER
  TARIK_TUNAI
  TOPUP_PULSA
  TOPUP_DATA
  TOPUP_EWALLET
  TOPUP_PLN
}

enum BrilinkTransactionStatus {
  SUCCESS
  FAILED
  PENDING
  VOIDED
}

enum BrilinkFeeType {
  FLAT
  PERCENT
}

model BrilinkTransaction {
  id              String                   @id @default(cuid())
  shop            Shop                     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  shopId          String
  cashier         User                     @relation("BrilinkCashier", fields: [cashierId], references: [id])
  cashierId       String
  account         BrilinkAccount?          @relation(fields: [accountId], references: [id])
  accountId       String?

  refNumber       String                   @unique
  category        BrilinkCategory
  customer        Customer?                @relation(fields: [customerId], references: [id])
  customerId      String?
  customerName    String
  customerPhone   String?
  destination     String
  amount          Int                      // nominal transaksi (rupiah)
  fee             Int                      @default(0) // fee yang dikenakan
  total           Int                      // amount + fee
  status          BrilinkTransactionStatus @default(SUCCESS)

  // Fee method for TARIK_TUNAI (how admin fee is charged)
  // DALAM = fee added to rekening debit (nasabah tarik nominal+fee dari rek)
  // LUAR = fee paid cash separately (saldo tetap, fee masuk kas tunai)
  // POTONG = fee deducted from cash given (nasabah terima nominal-fee)
  feeMethod       String?                  // 'DALAM' | 'LUAR' | 'POTONG' (null for non-tarik)

  // Kartu Customer: sumber dana = kartu nasabah sendiri
  // Jika true: accountImpact=0, cashImpact=+adminFee saja
  isCustomerCard  Boolean                  @default(false)

  // Flow & Impact fields
  flowDirection   String?                  // 'DEBIT' | 'CREDIT' (auto-derived from category)
  accountImpact   Int                      @default(0) // signed: negative for debit, positive for credit
  cashImpact      Int                      @default(0) // signed: impact on kas tunai

  // Offline support
  idempotencyKey  String?                  @unique
  clientCreatedAt DateTime?

  // Void support
  voidedAt        DateTime?
  voidedBy        String?
  voidReason      String?

  // Link to cash mutation (for traceability)
  cashMutationId  String?

  createdAt       DateTime                 @default(now())
  updatedAt       DateTime                 @updatedAt

  @@index([shopId])
  @@index([cashierId])
  @@index([category])
  @@index([createdAt])
  @@index([status])
  @@map("brilink_transactions")
}

model BrilinkFee {
  id              String          @id @default(cuid())
  shop            Shop            @relation(fields: [shopId], references: [id], onDelete: Cascade)
  shopId          String
  category        BrilinkCategory
  label           String          // "Transfer BRI 1-50jt", etc
  minAmount       Int             @default(0)
  maxAmount       Int             @default(999999999)
  systemFee       Int             @default(0) // biaya sistem/bank (bukan profit, potongan tetap)
  feeType         BrilinkFeeType  @default(FLAT)
  feeAmount       Int             @default(0) // admin fee flat (rupiah) — profit agen
  feePercent      Float           @default(0) // admin fee percent (e.g. 0.5 = 0.5%) — profit agen
  isActive        Boolean         @default(true)

  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([shopId, category, isActive])
  @@map("brilink_fees")
}


// ============================================
// BRILINK ACCOUNTS & MUTATIONS
// ============================================

enum BrilinkMutationType {
  SETOR
  TARIK
  TRX_DEBIT
  TRX_CREDIT
  ADJUSTMENT
  TRANSFER_OUT
  TRANSFER_IN
}

model BrilinkAccount {
  id                    String    @id @default(cuid())
  shop                  Shop      @relation(fields: [shopId], references: [id], onDelete: Cascade)
  shopId                String
  label                 String
  accountNumber         String
  accountHolder         String?
  balance               Int       @default(0)
  lowBalanceThreshold   Int       @default(1000000)
  isDefault             Boolean   @default(false)
  isActive              Boolean   @default(true)
  notes                 String?
  mutations             BrilinkMutation[]
  transactions          BrilinkTransaction[]
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@unique([shopId, accountNumber])
  @@index([shopId])
  @@map("brilink_accounts")
}

model BrilinkMutation {
  id              String              @id @default(cuid())
  account         BrilinkAccount      @relation(fields: [accountId], references: [id], onDelete: Cascade)
  accountId       String
  type            BrilinkMutationType
  amount          Int
  balanceBefore   Int
  balanceAfter    Int
  reference       String?
  description     String
  notes           String?
  createdById     String?
  createdBy       User?               @relation("BrilinkMutationCreator", fields: [createdById], references: [id])
  createdAt       DateTime            @default(now())

  @@index([accountId])
  @@index([createdAt])
  @@map("brilink_mutations")
}


// ============================================
// BRILINK CASH BOX (KAS TUNAI BRILINK)
// ============================================
//
// Kas tunai BRILink 100% terpisah dari kas retail (CashBox).
// 1 shop = 1 BrilinkCashBox.
// Saldo naik saat nasabah bayar tunai (transfer/topup), turun saat tarik tunai.

enum BrilinkCashMutationType {
  TRX_IN          // Dari transaksi: nasabah bayar tunai
  TRX_OUT         // Dari transaksi: agen kasih tunai (tarik tunai)
  SETOR           // Admin tambah modal kas tunai
  TARIK           // Admin ambil tunai
  ADJUSTMENT      // Koreksi dari reconciliation
  VOID_REVERSE    // Reversal dari void transaksi
}

model BrilinkCashBox {
  id                  String    @id @default(cuid())
  shop                Shop      @relation(fields: [shopId], references: [id], onDelete: Cascade)
  shopId              String    @unique  // 1 kas tunai per shop
  balance             Int       @default(0)
  lowBalanceThreshold Int       @default(2000000)
  lastAudit           DateTime?
  lastAuditBalance    Int?
  notes               String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  mutations           BrilinkCashMutation[]

  @@map("brilink_cash_boxes")
}

model BrilinkCashMutation {
  id              String                  @id @default(cuid())
  cashBox         BrilinkCashBox          @relation(fields: [cashBoxId], references: [id], onDelete: Cascade)
  cashBoxId       String
  type            BrilinkCashMutationType
  amount          Int                     // always positive
  balanceBefore   Int
  balanceAfter    Int
  reference       String?                 // brilinkTransaction.id or reconciliation.id
  description     String
  notes           String?
  createdById     String?
  createdAt       DateTime                @default(now())

  @@index([cashBoxId])
  @@index([createdAt])
  @@map("brilink_cash_mutations")
}

// ============================================
// BRILINK RECONCILIATION
// ============================================

model BrilinkReconciliation {
  id              String    @id @default(cuid())
  shop            Shop      @relation(fields: [shopId], references: [id], onDelete: Cascade)
  shopId          String
  target          String    // 'ACCOUNT' | 'CASHBOX'
  targetId        String    // accountId or cashBoxId
  targetLabel     String    // "BRI Utama" or "Kas Tunai"
  balanceApp      Int       // saldo di app sebelum adjustment
  balanceReal     Int       // saldo real yang diinput admin
  adjustment      Int       // selisih (real - app)
  status          String    // 'MATCHED' | 'ADJUSTED'
  notes           String?
  createdById     String
  createdAt       DateTime  @default(now())

  @@index([shopId])
  @@index([createdAt])
  @@map("brilink_reconciliations")
}


// ============================================
// BRILINK PRODUCTS, OPERATORS & PROVIDERS
// ============================================

model OperatorPrefix {
  id        String  @id @default(cuid())
  prefix    String  @unique  // "0811", "0878", etc
  operator  String  // TELKOMSEL, XL, INDOSAT, THREE, AXIS, SMARTFREN
  type      String  @default("GSM")

  @@index([prefix])
  @@map("operator_prefixes")
}

model BrilinkProduct {
  id        String   @id @default(cuid())
  shop      Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  shopId    String
  category  String   // TOPUP_PULSA, TOPUP_DATA, TOPUP_EWALLET, TOPUP_PLN
  operator  String?  // TELKOMSEL, XL, etc (null for PLN/EWALLET)
  provider  String?  // GOPAY, OVO, etc (null for pulsa/PLN)
  name      String   // "Pulsa 10rb", "XL 3GB 30hr", "Token 50rb"
  nominal   Int?     // 10000, 50000 (null for paket data custom)
  buyPrice  Int      // harga beli dari BRI/supplier
  sellPrice Int      // harga jual ke nasabah
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([shopId, category, operator])
  @@index([shopId, category, provider])
  @@map("brilink_products")
}

model BankList {
  id        String  @id @default(cuid())
  code      String  @unique  // kode BI: "014", "008"
  name      String  // "Bank Central Asia"
  shortName String  // "BCA"
  isActive  Boolean @default(true)

  @@index([isActive])
  @@map("bank_list")
}

model EwalletProvider {
  id        String  @id @default(cuid())
  code      String  @unique  // "GOPAY", "OVO"
  name      String  // "GoPay"
  icon      String? // optional icon/emoji
  isActive  Boolean @default(true)

  @@map("ewallet_providers")
}


// ============================================
// SUPPLIER & PURCHASE ORDER MANAGEMENT
// ============================================

model Supplier {
  id              String    @id @default(cuid())
  shop            Shop      @relation(fields: [shopId], references: [id], onDelete: Cascade)
  shopId          String
  name            String
  phone           String?
  address         String?
  notes           String?
  isActive        Boolean   @default(true)

  purchaseOrders  PurchaseOrder[]

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([shopId])
  @@map("suppliers")
}

enum PurchaseOrderStatus {
  DRAFT
  ORDERED
  PARTIAL
  RECEIVED
  CANCELLED
}

model PurchaseOrder {
  id              String              @id @default(cuid())
  shop            Shop                @relation(fields: [shopId], references: [id], onDelete: Cascade)
  shopId          String
  supplier        Supplier            @relation(fields: [supplierId], references: [id])
  supplierId      String
  createdBy       User                @relation("POCreator", fields: [createdById], references: [id])
  createdById     String

  orderNumber     String              @unique
  status          PurchaseOrderStatus @default(DRAFT)
  totalAmount     Int                 @default(0)
  notes           String?
  orderedAt       DateTime?
  receivedAt      DateTime?

  items           PurchaseOrderItem[]

  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@index([shopId])
  @@index([supplierId])
  @@index([status])
  @@index([createdAt])
  @@map("purchase_orders")
}

model PurchaseOrderItem {
  id              String        @id @default(cuid())
  order           PurchaseOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId         String
  product         Product       @relation(fields: [productId], references: [id])
  productId       String

  quantity        Int
  unitCost        Int           // harga beli per unit (rupiah)
  subtotal        Int           // quantity * unitCost
  receivedQty     Int           @default(0)

  @@index([orderId])
  @@index([productId])
  @@map("purchase_order_items")
}



// ============================================
// STOCK TRANSFER BETWEEN BRANCHES
// ============================================

enum StockTransferStatus {
  PENDING
  APPROVED
  IN_TRANSIT
  RECEIVED
  REJECTED
  CANCELLED
}

model StockTransfer {
  id              String              @id @default(cuid())
  fromShop        Shop                @relation("TransferFrom", fields: [fromShopId], references: [id])
  fromShopId      String
  toShop          Shop                @relation("TransferTo", fields: [toShopId], references: [id])
  toShopId        String
  requestedBy     User                @relation("TransferRequester", fields: [requestedById], references: [id])
  requestedById   String
  approvedBy      User?               @relation("TransferApprover", fields: [approvedById], references: [id])
  approvedById    String?

  transferNumber  String              @unique
  status          StockTransferStatus @default(PENDING)
  notes           String?
  approvalNotes   String?
  requestedAt     DateTime            @default(now())
  approvedAt      DateTime?
  shippedAt       DateTime?
  receivedAt      DateTime?

  items           StockTransferItem[]

  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@index([fromShopId])
  @@index([toShopId])
  @@index([status])
  @@index([createdAt])
  @@map("stock_transfers")
}

model StockTransferItem {
  id              String        @id @default(cuid())
  transfer        StockTransfer @relation(fields: [transferId], references: [id], onDelete: Cascade)
  transferId      String
  product         Product       @relation(fields: [productId], references: [id])
  productId       String

  quantity        Int
  receivedQty     Int           @default(0)

  @@index([transferId])
  @@index([productId])
  @@map("stock_transfer_items")
}



// ============================================
// RACK MANAGEMENT (Zona → Rak)
// ============================================

model RackZone {
  id              String    @id @default(cuid())
  shop            Shop      @relation(fields: [shopId], references: [id], onDelete: Cascade)
  shopId          String
  name            String    // e.g. "Minuman Dingin", "Snack", "Kebutuhan Pokok"
  description     String?
  sortOrder       Int       @default(0)

  racks           Rack[]

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([shopId, name])
  @@index([shopId])
  @@map("rack_zones")
}

model Rack {
  id              String    @id @default(cuid())
  shop            Shop      @relation(fields: [shopId], references: [id], onDelete: Cascade)
  shopId          String
  zone            RackZone  @relation(fields: [zoneId], references: [id], onDelete: Cascade)
  zoneId          String
  code            String    // e.g. "A1", "B-03" — unique per shop
  name            String?   // optional descriptive name e.g. "Rak Atas Kiri"

  stocks          Stock[]

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([shopId, code])
  @@index([shopId])
  @@index([zoneId])
  @@map("racks")
}


// ============================================
// ROLE PERMISSIONS (RBAC)
// ============================================
//
// Super Admin bisa toggle permission per-role.
// Default permissions di-seed saat pertama kali.
// Kalau row tidak ada untuk suatu permission → fallback ke default (deny).

model RolePermission {
  id          String    @id @default(cuid())
  role        Role
  permission  String    // e.g. "transactions.void", "products.delete", "users.manage"
  enabled     Boolean   @default(false)

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([role, permission])
  @@index([role])
  @@map("role_permissions")
}


// ============================================
// SAAS MULTI-TENANT + SUBSCRIPTION
// ============================================

enum PlanType {
  TRIAL
  STARTER
  BRILINK
  PRO
  BUSINESS
}

enum CycleType {
  MONTHLY
  YEARLY
  LIFETIME
}

enum SubStatus {
  TRIAL
  ACTIVE
  EXPIRED
  SUSPENDED
  CANCELLED
  LIFETIME
}

enum SaasPaymentStatus {
  PENDING
  VERIFIED
  REJECTED
  EXPIRED
}

model Tenant {
  id            String    @id @default(cuid())
  name          String    // Nama toko/bisnis
  slug          String    @unique // URL-friendly (auto-generated dari name)
  ownerName     String    // Nama pemilik
  ownerPhone    String    // No WA pemilik
  ownerEmail    String    @unique // Email pemilik (untuk login)
  isActive      Boolean   @default(true) // Soft-disable oleh owner platform

  subscription  Subscription?
  shops         Shop[]
  users         User[]
  payments      SaasPayment[]

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([ownerEmail])
  @@index([isActive])
  @@map("tenants")
}

model Subscription {
  id            String    @id @default(cuid())
  tenant        Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tenantId      String    @unique

  plan          PlanType  @default(TRIAL)
  cycle         CycleType @default(MONTHLY)
  status        SubStatus @default(TRIAL)

  startDate     DateTime  @default(now())
  endDate       DateTime? // null = lifetime (tidak pernah expire)
  graceEndsAt   DateTime? // endDate + 7 hari

  // Plan limits
  maxBranches   Int       @default(1)
  maxUsers      Int       @default(2)
  maxProducts   Int       @default(50)

  // Feature flags per plan
  brilinkEnabled    Boolean @default(false)
  ppobEnabled       Boolean @default(false)
  shiftEnabled      Boolean @default(false)
  multiUserEnabled  Boolean @default(false)
  exportEnabled     Boolean @default(false)
  opnameEnabled     Boolean @default(false)
  supplierEnabled   Boolean @default(false)
  transferEnabled   Boolean @default(false)
  labelPrintEnabled Boolean @default(false)
  rackEnabled       Boolean @default(false)
  apiIntegrationEnabled Boolean @default(false)

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([status])
  @@index([endDate])
  @@map("subscriptions")
}

model SaasPayment {
  id            String             @id @default(cuid())
  tenant        Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tenantId      String

  amount        Int                // Rupiah
  method        String             // SEABANK, BCA, QRIS, DANA, OVO, GOPAY
  plan          PlanType
  cycle         CycleType

  status        SaasPaymentStatus  @default(PENDING)
  proofUrl      String?            // URL bukti transfer (upload)
  uniqueCode    String?            // Kode unik transfer (3 digit terakhir)
  notes         String?

  verifiedAt    DateTime?
  verifiedBy    String?            // Owner platform yang verify
  rejectedAt    DateTime?
  rejectedReason String?

  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  @@index([tenantId])
  @@index([status])
  @@index([createdAt])
  @@map("saas_payments")
}


// ============================================
// CUSTOMERS (Anti-Double Name)
// ============================================

model Customer {
  id          String   @id @default(cuid())
  shop        Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  shopId      String
  name        String
  phone       String?
  address     String?
  notes       String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  transactions        Transaction[]
  brilinkTransactions BrilinkTransaction[]

  @@unique([shopId, name])
  @@index([shopId])
  @@index([name])
  @@map("customers")
}



// ============================================
// TRIPAY PPOB INTEGRATION
// ============================================

model TripayConfig {
  id              String    @id @default(cuid())
  shop            Shop      @relation(fields: [shopId], references: [id], onDelete: Cascade)
  shopId          String    @unique
  apiKey          String
  privateKey      String
  merchantCode    String
  pin             String?   // PIN transaksi 4 digit akun Tripay
  mode            String    @default("sandbox") // sandbox | production
  isActive        Boolean   @default(true)
  lastVerifiedAt  DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@map("tripay_configs")
}

model PpobTransaction {
  id              String    @id @default(cuid())
  shop            Shop      @relation(fields: [shopId], references: [id], onDelete: Cascade)
  shopId          String
  cashierId       String
  refId           String    @unique // Our internal reference
  tripayRef       String?   // Tripay's reference/trx_id
  productCode     String
  customerId      String    // No pelanggan / tujuan
  customerName    String?
  customerPhone   String?
  type            String    // prepaid | postpaid
  amount          Float     @default(0)
  fee             Float     @default(0)
  total           Float     @default(0)
  status          String    @default("PROCESSING") // PROCESSING | SUCCESS | FAILED | REFUNDED
  tripayStatus    String?   // Raw status from Tripay
  serialNumber    String?   // SN token PLN, voucher, dll
  rawResponse     String?   // JSON string of Tripay response
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([shopId, createdAt])
  @@index([shopId, status])
  @@index([refId])
  @@map("ppob_transactions")
}
