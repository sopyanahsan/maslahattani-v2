// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// AUTHENTICATION & USER MANAGEMENT
// ============================================

enum Role {
  SUPER_ADMIN
  ADMIN
  KASIR
  CASHIER_SUPERVISOR
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

model User {
  id                  String    @id @default(cuid())
  email               String    @unique
  username            String?   @unique
  passwordHash        String
  role                Role      @default(KASIR)
  status              UserStatus @default(ACTIVE)
  shop                Shop?     @relation("ShopUsers", fields: [shopId], references: [id])
  shopId              String?
  
  lastLogin           DateTime?
  lastPasswordReset   DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  
  sessions            Session[]
  activityLogs        ActivityLog[]
  transactions        Transaction[]
  shifts              Shift[]
  ownedShops          Shop[]    @relation("ShopOwner")

  @@index([shopId])
  @@index([email])
  @@map("users")
}

model Session {
  id                  String    @id @default(cuid())
  user                User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId              String
  token               String    @unique
  refreshToken        String    @unique
  expiresAt           DateTime
  refreshExpiresAt    DateTime
  ipAddress           String?
  userAgent           String?
  createdAt           DateTime  @default(now())
  
  @@index([userId])
  @@index([token])
  @@map("sessions")
}

model ActivityLog {
  id                  String    @id @default(cuid())
  user                User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId              String
  action              String    // LOGIN, TRANSACTION, VOID, etc
  resource            String?   // TRANSACTION, PRODUCT, STOCK, etc
  resourceId          String?
  details             String?   // JSON details
  ipAddress           String?
  createdAt           DateTime  @default(now())
  
  @@index([userId])
  @@index([createdAt])
  @@map("activity_logs")
}

// ============================================
// SHOP MANAGEMENT
// ============================================

model Shop {
  id                  String    @id @default(cuid())
  name                String
  address             String
  phone               String
  owner               User?     @relation("ShopOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  ownerId             String?
  parentShop          Shop?     @relation("ShopToParent", fields: [parentShopId], references: [id], onDelete: SetNull)
  parentShopId        String?
  childShops          Shop[]    @relation("ShopToParent")
  
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  
  users               User[]    @relation("ShopUsers")
  products            Product[]
  stocks              Stock[]
  transactions        Transaction[]
  debts               Debt[]
  payments            Payment[]
  cashBoxes           CashBox[]
  shifts              Shift[]
  settings            ShopSetting?

  // BRILink relations
  brilinkAccounts     BrilinkAccount[]     @relation("ShopBrilinkAccounts")
  brilinkMutations    BrilinkMutation[]    @relation("ShopBrilinkMutations")
  brilinkTransactions BrilinkTransaction[] @relation("ShopBrilinkTransactions")
  brilinkFees         BrilinkFee[]         @relation("ShopBrilinkFees")

  @@map("shops")
}

model ShopSetting {
  id                  String    @id @default(cuid())
  shop                Shop      @relation(fields: [shopId], references: [id], onDelete: Cascade)
  shopId              String    @unique
  language            String    @default("id") // "id", "en", "su", "jv"
  receiptConfig       String?   // JSON config for receipt printing
  updatedAt           DateTime  @updatedAt
  
  @@map("shop_settings")
}

// ============================================
// CASH BOX CATEGORIES (multi-kas)
// ============================================
//
// Toko bisa punya beberapa "kas" terpisah yang regulasi/audit-nya beda:
// - RETAIL: kas penjualan biasa (default)
// - SUBSIDI_PUPUK: kas subsidi pemerintah, terpisah karena ada laporan ke
//   Pupuk Indonesia / Kementan dan margin diatur HET pemerintah
// - LPG_SUBSIDI / BERAS_BULOG / dll bisa ditambah via admin panel
//
// CashBoxCategory di-manage SUPER_ADMIN saja (global, semua cabang pakai
// kategori yang sama biar reporting cross-cabang konsisten).
//
// Per cabang akan punya saldo terpisah lewat ShiftCashBox (akumulasi dari
// shift-shift yang sudah finalized).

model CashBoxCategory {
  id            String    @id @default(cuid())
  code          String    @unique // "RETAIL", "SUBSIDI_PUPUK", dst (UPPERCASE)
  name          String              // "Kas Retail", "Kas Subsidi Pupuk"
  description   String?
  /** Tailwind color class (mis "blue", "amber") atau hex untuk badge UI */
  color         String?
  /** Lucide icon name, mis "shopping-cart", "wheat" */
  icon          String?
  /** Default category yang dipakai kalau produk belum di-assign kategori. */
  isDefault     Boolean   @default(false)
  /** Soft-disable. False = tidak tampil di UI buka shift / POS. */
  isActive      Boolean   @default(true)
  sortOrder     Int       @default(0)

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  shiftCashBoxes ShiftCashBox[]

  @@index([isActive, sortOrder])
  @@map("cash_box_categories")
}

// ============================================
// PRODUCTS & INVENTORY
// ============================================

model Product {
  id                  String    @id @default(cuid())
  shop                Shop      @relation(fields: [shopId], references: [id], onDelete: Cascade)
  shopId              String
  name                String
  sku                 String
  price               Int       // in rupiah
  cost                Int       // in rupiah
  supplierId          String?   // future: Supplier model
  
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  deletedAt           DateTime?
  
  stocks              Stock[]
  transactionItems    TransactionItem[]
  debts               Debt[]

  @@unique([shopId, sku])
  @@index([shopId])
  @@map("products")
}

model Stock {
  id                  String    @id @default(cuid())
  shop                Shop      @relation(fields: [shopId], references: [id], onDelete: Cascade)
  shopId              String
  product             Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId           String
  quantity            Int       @default(0)
  warehouse           String?   @default("main")
  
  updatedAt           DateTime  @updatedAt
  
  stockHistories      StockHistory[]

  @@unique([shopId, productId, warehouse])
  @@index([shopId])
  @@index([productId])
  @@map("stocks")
}

enum StockHistoryType {
  IN
  OUT
  OPNAME
  TRANSFER_OUT
  TRANSFER_IN
  ADJUSTMENT
}

model StockHistory {
  id                  String    @id @default(cuid())
  stock               Stock     @relation(fields: [stockId], references: [id], onDelete: Cascade)
  stockId             String
  type                StockHistoryType
  quantityBefore      Int
  quantityAfter       Int
  quantityChange      Int
  reference           String?   // transaction_id, opname_id, etc
  notes               String?
  
  createdAt           DateTime  @default(now())
  
  @@index([stockId])
  @@index([createdAt])
  @@map("stock_histories")
}

// ============================================
// TRANSACTIONS & SALES
// ============================================

enum TransactionStatus {
  PENDING
  COMPLETED
  VOIDED
  PROCESSING
}

enum PaymentMethod {
  CASH
  QRIS
  TRANSFER
  HUTANG
}

model Transaction {
  id                  String    @id @default(cuid())
  shop                Shop      @relation(fields: [shopId], references: [id], onDelete: Cascade)
  shopId              String
  user                User      @relation(fields: [userId], references: [id])
  userId              String
  transactionNumber   String    @unique
  
  totalPrice          Int       // in rupiah
  totalCost           Int       // in rupiah
  totalDiscount       Int       @default(0)
  status              TransactionStatus @default(PENDING)
  
  // Offline-ready fields
  // idempotencyKey: client-generated UUID untuk dedup retry saat sinyal jelek.
  //   Sama key = transaksi yang sama, server kembalikan record existing tanpa create dobel.
  // clientCreatedAt: waktu transaksi sebenarnya di sisi kasir (saat scan + bayar),
  //   bisa berbeda dari createdAt (yang ditulis saat sync ke server).
  idempotencyKey      String?   @unique
  clientCreatedAt     DateTime?
  
  items               TransactionItem[]
  payments            Payment[]
  
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  voidedAt            DateTime?
  voidedBy            String?   // admin username/id
  voidReason          String?
  
  @@index([shopId])
  @@index([userId])
  @@index([createdAt])
  @@map("transactions")
}

model TransactionItem {
  id                  String    @id @default(cuid())
  transaction         Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  transactionId       String
  product             Product   @relation(fields: [productId], references: [id])
  productId           String
  
  quantity            Int
  unitPrice           Int       // in rupiah (saat transaksi)
  discount            Int       @default(0)
  subtotal            Int       // quantity * unitPrice - discount
  
  @@index([transactionId])
  @@index([productId])
  @@map("transaction_items")
}

// ============================================
// PAYMENTS & CASH MANAGEMENT
// ============================================

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  CANCELLED
}

model Payment {
  id                  String    @id @default(cuid())
  shop                Shop      @relation(fields: [shopId], references: [id], onDelete: Cascade)
  shopId              String
  transaction         Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  transactionId       String
  
  method              PaymentMethod
  amount              Int       // in rupiah
  status              PaymentStatus @default(PENDING)
  reference           String?   // QRIS ref, transfer ref, etc
  
  createdAt           DateTime  @default(now())
  
  @@index([shopId])
  @@index([transactionId])
  @@map("payments")
}

model CashBox {
  id                  String    @id @default(cuid())
  shop                Shop      @relation(fields: [shopId], references: [id], onDelete: Cascade)
  shopId              String    @unique
  
  balance             Int       @default(0) // in rupiah
  lastAudit           DateTime?
  lastAuditBalance    Int?
  
  updatedAt           DateTime  @updatedAt
  
  @@map("cash_boxes")
}

// ============================================
// DEBTS MANAGEMENT
// ============================================

enum DebtStatus {
  PENDING
  PARTIALLY_PAID
  PAID
  OVERDUE
  CANCELLED
}

model Debt {
  id                  String    @id @default(cuid())
  shop                Shop      @relation(fields: [shopId], references: [id], onDelete: Cascade)
  shopId              String
  product             Product   @relation(fields: [productId], references: [id])
  productId           String
  
  customerName        String
  customerPhone       String?
  quantity            Int
  unitPrice           Int       // in rupiah (saat hutang dibuat)
  totalAmount         Int       // quantity * unitPrice
  paidAmount          Int       @default(0)
  status              DebtStatus @default(PENDING)
  
  dueDate             DateTime?
  notes               String?
  
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  
  debtPayments        DebtPayment[]
  
  @@index([shopId])
  @@index([status])
  @@map("debts")
}

model DebtPayment {
  id                  String    @id @default(cuid())
  debt                Debt      @relation(fields: [debtId], references: [id], onDelete: Cascade)
  debtId              String
  
  amount              Int       // in rupiah
  method              PaymentMethod
  reference           String?
  notes               String?
  
  createdAt           DateTime  @default(now())
  
  @@index([debtId])
  @@map("debt_payments")
}

// ============================================
// SHIFT MANAGEMENT & CLEREK
// ============================================

enum ShiftStatus {
  OPEN
  CLOSED
  FINALIZED
}

model Shift {
  id                  String    @id @default(cuid())
  shop                Shop      @relation(fields: [shopId], references: [id], onDelete: Cascade)
  shopId              String
  user                User      @relation(fields: [userId], references: [id])
  userId              String
  
  startTime           DateTime
  endTime             DateTime?
  
  status              ShiftStatus @default(OPEN)
  notes               String?
  finalizedAt         DateTime?
  finalizedBy         String?   // admin username
  
  /**
   * Per-category breakdown of cash & QRIS for this shift.
   * Setiap kategori (RETAIL, SUBSIDI_PUPUK, dst) punya 1 row di sini dengan
   * starting cash, expected vs actual, dan variance terpisah.
   *
   * Saat openShift: dibuat row per active category dengan startingCash dari
   *   input kasir.
   * Saat closeShift: expectedCash/QRIS dihitung dari transaksi shift, kasir
   *   input actualCash/QRIS, sistem hitung variance.
   */
  cashBoxes           ShiftCashBox[]

  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  
  @@index([shopId])
  @@index([userId])
  @@index([status])
  @@map("shifts")
}

/**
 * Per-category snapshot dari shift. Satu Shift bisa punya beberapa
 * ShiftCashBox (mis: kas RETAIL + kas SUBSIDI_PUPUK).
 *
 * Diisi step-by-step:
 * 1. Open shift: startingCash di-input kasir, expected/actual masih 0/null.
 * 2. Selama shift: setiap transaksi update expectedCash/QRIS via service.
 *    (Untuk sekarang masih dihitung on-demand saat closeShift dari sum
 *     payments. Optimization caching bisa nanti.)
 * 3. Close shift: kasir input actualCash & actualQRIS, sistem hitung
 *    varianceCash & varianceQRIS.
 */
model ShiftCashBox {
  id                  String          @id @default(cuid())
  shift               Shift           @relation(fields: [shiftId], references: [id], onDelete: Cascade)
  shiftId             String
  category            CashBoxCategory @relation(fields: [categoryId], references: [id])
  categoryId          String

  startingCash        Int      @default(0) // input saat buka shift (rupiah)
  expectedCash        Int      @default(0) // computed dari payments CASH
  actualCash          Int?               // input saat tutup shift
  varianceCash        Int?               // actualCash - (startingCash + expectedCash)

  expectedQRIS        Int      @default(0) // computed dari payments QRIS
  actualQRIS          Int?
  varianceQRIS        Int?

  /**
   * Breakdown denominasi uang fisik saat tutup shift.
   * Format JSON object: { "100000": 5, "50000": 3, ..., "100": 0, "lainnya": 5000 }
   *  - key = nominal lembar/koin (rupiah string), kecuali "lainnya"
   *  - value = jumlah lembar (count) untuk semua kunci kecuali "lainnya"
   *  - "lainnya" = nominal raw (rupiah) untuk koin/recehan/lain yg tdk masuk slot.
   *
   * Optional: kalau kasir tidak input denominasi, field null. actualCash
   * tetap dipakai sebagai source of truth.
   *
   * Server validate: sum(key * value for key != "lainnya") + lainnya == actualCash.
   */
  cashDenominations   Json?

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@unique([shiftId, categoryId])
  @@index([shiftId])
  @@index([categoryId])
  @@map("shift_cash_boxes")
}


// ============================================
// BRILINK MODULE
// ============================================
//
// BrilinkAccount  : Rekening BRI milik agen. Bisa >1 per toko.
// BrilinkMutation : Mutasi saldo rekening BRILink (credit/debit).
// BrilinkTransaction: Transaksi layanan ke nasabah (transfer, tarik, top-up).
// BrilinkFee      : Pengaturan fee per kategori & range nominal.

enum BrilinkTransactionCategory {
  TRANSFER_BRI
  TRANSFER_OTHER
  TARIK_TUNAI
  TOPUP_PULSA
  TOPUP_DATA
  TOPUP_EWALLET
  TOPUP_PLN

  @@map("BrilinkTransactionCategory")
}

enum BrilinkTransactionStatus {
  SUCCESS
  PENDING
  FAILED
  CANCELLED

  @@map("BrilinkTransactionStatus")
}

enum BrilinkMutationType {
  CREDIT
  DEBIT

  @@map("BrilinkMutationType")
}

enum BrilinkFeeType {
  FLAT
  PERCENT

  @@map("BrilinkFeeType")
}

model BrilinkAccount {
  id            String   @id @default(cuid())
  shop          Shop     @relation("ShopBrilinkAccounts", fields: [shopId], references: [id], onDelete: Cascade)
  shopId        String
  accountNumber String
  accountName   String
  bankName      String   @default("BRI")
  balance       Int      @default(0) // current balance in rupiah
  isActive      Boolean  @default(true)
  isPrimary     Boolean  @default(false) // satu per toko sebagai rekening utama
  notes         String?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  mutations     BrilinkMutation[]
  transactions  BrilinkTransaction[]

  @@unique([shopId, accountNumber])
  @@index([shopId])
  @@map("brilink_accounts")
}

model BrilinkMutation {
  id            String              @id @default(cuid())
  account       BrilinkAccount      @relation(fields: [accountId], references: [id], onDelete: Cascade)
  accountId     String
  shop          Shop                @relation("ShopBrilinkMutations", fields: [shopId], references: [id], onDelete: Cascade)
  shopId        String
  type          BrilinkMutationType
  amount        Int                 // rupiah
  balanceBefore Int
  balanceAfter  Int
  description   String
  reference     String?             // brilinkTransactionId atau manual ref

  createdAt     DateTime @default(now())

  @@index([accountId])
  @@index([shopId])
  @@index([createdAt])
  @@map("brilink_mutations")
}

model BrilinkTransaction {
  id           String                      @id @default(cuid())
  shop         Shop                        @relation("ShopBrilinkTransactions", fields: [shopId], references: [id], onDelete: Cascade)
  shopId       String
  account      BrilinkAccount?             @relation(fields: [accountId], references: [id], onDelete: SetNull)
  accountId    String?
  refNumber    String                      @unique
  category     BrilinkTransactionCategory
  customerName String
  destination  String                      // nomor rekening/HP tujuan
  amount       Int                         // nominal transaksi
  fee          Int                         @default(0)
  total        Int                         // amount + fee
  status       BrilinkTransactionStatus    @default(PENDING)
  notes        String?
  processedBy  String?                     // userId kasir

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([shopId])
  @@index([createdAt])
  @@index([category])
  @@map("brilink_transactions")
}

model BrilinkFee {
  id         String                      @id @default(cuid())
  shop       Shop                        @relation("ShopBrilinkFees", fields: [shopId], references: [id], onDelete: Cascade)
  shopId     String
  category   BrilinkTransactionCategory
  label      String
  minAmount  Int                         @default(0)
  maxAmount  Int                         @default(999999999)
  feeType    BrilinkFeeType              @default(FLAT)
  feeAmount  Int                         @default(0)   // untuk FLAT
  feePercent Float                       @default(0)   // untuk PERCENT
  isActive   Boolean                     @default(true)
  sortOrder  Int                         @default(0)

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([shopId])
  @@index([category])
  @@map("brilink_fees")
}
