# Application
NODE_ENV=development
PORT=3000
APP_NAME="Maslahat Tani v2"
APP_URL=http://localhost:3000

# Database
DATABASE_URL=postgresql://maslahat:maslahat123@localhost:5432/maslahat_tani

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRATION=86400
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-this
JWT_REFRESH_EXPIRATION=2592000

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Email (for OTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@maslahat-tani.com

# Logging
LOG_LEVEL=debug

# CORS
# Daftar origin yang diizinkan (Vite dev = :5173, kalau Nuxt/SSR lain bisa ditambahkan)
CORS_ORIGIN=http://localhost:5173,http://localhost:3001,http://localhost:3002

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
