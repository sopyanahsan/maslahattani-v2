# Application
NODE_ENV=development
PORT=3000
APP_NAME="Maslahat Tani v2"
APP_URL=http://localhost:3000

# Database
# Note: kalau host kamu udah ada Postgres native di :5432, set POSTGRES_PORT=5433
# di shell sebelum `docker compose up -d` lalu ubah port di DATABASE_URL ke 5433 juga.
DATABASE_URL=postgresql://maslahat:maslahat123@localhost:5432/maslahat_tani

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRATION=86400
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-this
JWT_REFRESH_EXPIRATION=2592000

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Email (for OTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@maslahat-tani.com

# Logging
LOG_LEVEL=debug

# CORS
# Daftar origin yang diizinkan.
# Dev: Vite di :5173. Prod: 2 subdomain (admin + webapp).
CORS_ORIGIN=http://localhost:5173,http://localhost:3001,http://localhost:3002,https://admin.maslahattani.my.id,https://maslahattani.my.id,https://www.maslahattani.my.id

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100


# Firebase Admin (Google OAuth verification)
# Setup: Firebase Console → Project Settings → Service accounts → Generate new private key
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nxxxxx\n-----END PRIVATE KEY-----\n"


# Platform Owner (comma-separated emails that have full platform access)
# These emails will NOT create a tenant when registering via Google.
# They get access to /owner dashboard (manage all tenants, verify payments).
PLATFORM_OWNER_EMAILS=tokomaslahattani@gmail.com
