# API base URL.
# - Dev:  backend NestJS jalan di :3000 → pakai default ini.
# - Prod: arahkan ke api.maslahattani.my.id yang di-proxy nginx ke localhost:3000.
VITE_API_BASE_URL=http://localhost:3000/api
VITE_APP_TITLE=Posify

# WebSocket real-time.
# Otomatis detect dari VITE_API_BASE_URL (strip /api).
# Override manual jika WebSocket server beda host.
# VITE_WS_URL=http://localhost:3000

# Webapp URL untuk link "Kasir Webapp" di admin home page.
# - Dev:  kosongkan (default '/webapp/' jadi link ke localhost:5173/webapp/).
# - Prod: set ke https://maslahattani.my.id supaya link cross-domain.
# VITE_WEBAPP_URL=https://maslahattani.my.id

# Cloudinary — product image upload (unsigned preset, client-side).
# Setup di Cloudinary Dashboard:
# 1. Settings > Upload > Upload presets > Add unsigned preset
# 2. Set folder: "ngalir/products"
# 3. Copy preset name ke VITE_CLOUDINARY_UPLOAD_PRESET
VITE_CLOUDINARY_CLOUD_NAME=drgnfwkpc
VITE_CLOUDINARY_UPLOAD_PRESET=upload_produk
